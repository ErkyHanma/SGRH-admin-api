@model SGRH.Web.Models.Hotel.Room.DeleteRoomModel
@{
    ViewData["Title"] = "Disable Room";
}
<h1>Delete a Room</h1>
<h3>Are you sure you want to delete this room?</h3>
<form asp-action="Delete">
    <input asp-for="roomId" type="hidden" />
    <div class="form-group">
        <label asp-for="updatedBy" class="control-label">Updated By (UserId)</label>
        <input asp-for="updatedBy" class="form-control" />
        <span asp-validation-for="updatedBy" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}