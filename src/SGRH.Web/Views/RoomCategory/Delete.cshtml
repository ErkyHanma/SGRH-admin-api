@model SGRH.Web.Models.Hotel.RoomCategory.DisableRoomCategoryModel

@{
    ViewData["Title"] = "Disable Room Category";
}

<h1>Disable Room Category</h1>

<h3>Are you sure you want to disable this room category?</h3>
<div>
    <h4>Room Category</h4>
    <hr />
    @* Opcional: Mostrar detalles de la categoría de habitación para confirmar, si no se usan en el modelo DisableRoomCategoryModel *@
    @* <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CategoryId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CategoryId)
        </dd>
        // Si quieres mostrar más datos de la categoría antes de deshabilitar, necesitas pasar el RoomCategoryModel completo o partes de él.
        // Por ahora, solo se muestra el ID que está en DisableRoomCategoryModel.
    </dl> *@

    <form asp-action="Delete">
        <input asp-for="CategoryId" type="hidden" />
        <div class="form-group">
            <label asp-for="UpdatedBy" class="control-label">Updated By (UserId)</label>
            <input asp-for="UpdatedBy" class="form-control" />
            <span asp-validation-for="UpdatedBy" class="text-danger"></span>
        </div>
        <div class="form-group">
            <input type="submit" value="Disable" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}