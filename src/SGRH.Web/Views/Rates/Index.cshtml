@model IEnumerable<SGRH.Web.Models.Hotel.Rates.RateModel>

@{
    ViewData["Title"] = "Index";
}

<h1>List of All Active Rates</h1>

<p>
    <a asp-action="Create">Create New Rate</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.rateId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.categoryId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.seasonId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.nightPrice)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.isActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.isDeleted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.createdAt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.createdBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.updatedBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.updatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.rateId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.categoryId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.seasonId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.nightPrice)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.isActive)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.isDeleted)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.createdAt)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.createdBy)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.updatedBy)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.updatedAt)
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.rateId }) |
                    @Html.ActionLink("Details", "Details", new { id = item.rateId }) |
                    @Html.ActionLink("Delete", "Delete", new { id = item.rateId })
                </td>
            </tr>
        }
    </tbody>
</table>
