@model SGRH.Application.Dtos.Hotel.Rate.UpdateRateDto

@{
    ViewData["Title"] = "Edit Rate";
}

<h1>Edit Rate</h1>
<h4>Fill the info to edit!</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="RateId" type="hidden" />

            <div class="form-group">
                <label asp-for="CategoryId" class="control-label">Category Id</label>
                <input asp-for="CategoryId" class="form-control" />
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SeasonId" class="control-label">Season Id</label>
                <input asp-for="SeasonId" class="form-control" />
                <span asp-validation-for="SeasonId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NightPrice" class="control-label">Night Price</label>
                <input asp-for="NightPrice" class="form-control" />
                <span asp-validation-for="NightPrice" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UpdatedBy" class="control-label">Updated By</label>
                <input asp-for="UpdatedBy" class="form-control" />
                <span asp-validation-for="UpdatedBy" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Changes" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
