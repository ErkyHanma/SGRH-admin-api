@model SGRH.Application.Dtos.Report.InputDtos.ServiceRevenueRequestDto

@{
    ViewData["Title"] = "Service Revenue Report";
}

<h2>Generate Service Revenue Report</h2>

<form asp-action="GetServiceRevenueReport" method="post">
    <div class="form-group">
        <label asp-for="CategoryId">Category ID (optional)</label>
        <input asp-for="CategoryId" type="number" class="form-control" />
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Generate Report</button>
</form>
